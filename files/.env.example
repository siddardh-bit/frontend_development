# Copy this file to ".env" and fill in your own values. Never commit the real .env.

# MongoDB connection string (free cluster at mongodb.com/atlas works fine)
MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster0.xxxxx.mongodb.net/dayzero?retryWrites=true&w=majority

# Gmail account that SENDS the notification emails.
# Use a Gmail App Password (16 chars), NOT your normal password. See README step 3.
SMTP_USER=your-sending-gmail@gmail.com
SMTP_PASS=your-16-char-app-password

# The site that's allowed to call this API (your frontend's URL).
# Use * while testing, then lock it to your real domain.
ALLOWED_ORIGIN=*

PORT=4000
